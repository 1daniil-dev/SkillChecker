<Window x:Class="SkillChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SkillChecker - Система тестирования" Height="800" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#F0F4F8">

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Auth -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="440"
                            Visibility="{Binding AuthVisibility}"
                            x:Name="AuthPanel"
                            AutomationProperties.Name="Экран авторизации">
                    <TextBlock Text="SkillChecker" FontSize="32" FontWeight="Bold" Foreground="#1E293B"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               AutomationProperties.Name="Название приложения"/>
                    <TextBlock Text="Система тестирования учащихся" FontSize="14" Foreground="#64748B"
                               HorizontalAlignment="Center" Margin="0,0,0,32"
                               AutomationProperties.Name="Подзаголовок"/>

                    <TextBlock Text="IP адрес сервера" FontWeight="SemiBold" FontSize="13" Foreground="#334155" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0"
                             VerticalContentAlignment="Center" Margin="0,0,0,10"
                             AutomationProperties.Name="IP адрес сервера"
                             AutomationProperties.HelpText="IP адрес компьютера преподавателя"/>

                    <TextBlock Text="Порт" FontWeight="SemiBold" FontSize="13" Foreground="#334155" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0"
                             VerticalContentAlignment="Center" Margin="0,0,0,10"
                             AutomationProperties.Name="Порт сервера"
                             AutomationProperties.HelpText="Порт сервера, по умолчанию 9000"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Button Content="Подключиться к серверу" Height="44" Padding="20,0" Margin="0,0,8,0"
                                Command="{Binding ConnectCommand}" Background="#E2E8F0" Foreground="#334155"
                                FontWeight="SemiBold" FontSize="14" BorderThickness="0"
                                AutomationProperties.Name="Подключиться к серверу"
                                AutomationProperties.HelpText="Установить соединение с сервером"/>
                        <Button Content="Обновить" Height="44" Padding="16,0"
                                Command="{Binding RefreshCommand}" Background="#4F46E5" Foreground="White"
                                FontWeight="SemiBold" FontSize="14" BorderThickness="0"
                                AutomationProperties.Name="Обновить список тестов"
                                AutomationProperties.HelpText="Обновить список тестов и расписание с сервера"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18"
                                AutomationProperties.Name="Статус подключения">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="#22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="Text" Value="Не подключено"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Foreground" Value="#166534"/>
                                            <Setter Property="Text" Value="Подключено"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding TestCountText}" FontSize="13" Foreground="#64748B"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="ФИО студента" FontWeight="SemiBold" FontSize="13" Foreground="#334155" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding StudentName, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0"
                             VerticalContentAlignment="Center" Margin="0,0,0,10"
                             AutomationProperties.Name="ФИО студента"
                             AutomationProperties.HelpText="Введите полное ФИО">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNameError}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Text="Учебная группа" FontWeight="SemiBold" FontSize="13" Foreground="#334155" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding StudentGroup, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="10,0"
                             VerticalContentAlignment="Center" Margin="0,0,0,18"
                             AutomationProperties.Name="Учебная группа"
                             AutomationProperties.HelpText="Введите номер группы">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGroupError}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Text="Выберите тест" FontWeight="SemiBold" FontSize="15" Foreground="#334155" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding TestCards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,10" Padding="16,14" HorizontalContentAlignment="Stretch"
                                        Command="{Binding DataContext.SelectTestCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Name}"
                                        AutomationProperties.Name="{Binding Name}"
                                        AutomationProperties.HelpText="Нажмите чтобы начать тест">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="cardBorder" CornerRadius="10" Padding="16,14"
                                                    BorderThickness="2" Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                        <Setter Property="BorderBrush" Value="#86EFAC"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                                                <Setter Property="Background" Value="#EBF3FC"/>
                                                                <Setter Property="BorderBrush" Value="#93B8E8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#86EFAC"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                                                        <Setter Property="Background" Value="#93B8E8"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Foreground="#1E3A5F" FontWeight="Bold" FontSize="16"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE823;"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#166534"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                                                            <Setter Property="Foreground" Value="#1E3A5F"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock FontSize="12" Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#64748B"/>
                                                                    <Setter Property="Text" Value="Доступен"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                                                            <Setter Property="Foreground" Value="#4A90D9"/>
                                                                            <Setter Property="Text" Value="Запланирован"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock FontSize="11" Foreground="#EF4444" Margin="0,1,0,0"
                                                                   Text="{Binding TimeMinutes, StringFormat='Лимит: {0} мин'}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TimeMinutes}" Value="0">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding ScheduleTime}" FontSize="16"
                                                               FontWeight="Bold" Foreground="#4A90D9"
                                                               VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsScheduled}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="cardBorder" Property="BorderBrush" Value="#4F46E5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Выход" Height="36" Margin="0,12,0,0"
                            Command="{Binding ExitCommand}" Background="Transparent" Foreground="#94A3B8"
                            BorderThickness="0" FontWeight="Normal"
                            AutomationProperties.Name="Выход из программы"/>
                </StackPanel>

                <!-- Wait -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400"
                            Visibility="{Binding WaitVisibility}"
                            x:Name="WaitPanel"
                            AutomationProperties.Name="Экран ожидания теста">
                    <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"
                               AutomationProperties.Name="Иконка часов"/>
                    <TextBlock Text="{Binding WaitTestName}" FontSize="24" FontWeight="Bold" Foreground="#1E293B"
                               HorizontalAlignment="Center" Margin="0,0,0,8"
                               AutomationProperties.Name="Название теста"/>
                    <TextBlock Text="{Binding WaitTimeText}" FontSize="16" Foreground="#64748B"
                               HorizontalAlignment="Center" Margin="0,0,0,24"
                               AutomationProperties.Name="Время начала теста"/>
                    <TextBlock Text="{Binding WaitCountdownText}" FontSize="48" FontWeight="Black" Foreground="#4F46E5"
                               HorizontalAlignment="Center" Margin="0,0,0,32"
                               AutomationProperties.Name="Обратный отсчёт"
                               AutomationProperties.HelpText="Время до начала теста"
                               AutomationProperties.LiveSetting="Polite"/>
                    <Button Content="Начать тест" Height="48" Width="260"
                            Command="{Binding StartFromWaitCommand}" Background="#4F46E5" Foreground="White"
                            FontWeight="Bold" FontSize="15" BorderThickness="0"
                            AutomationProperties.Name="Начать тест"
                            AutomationProperties.HelpText="{Binding WaitButtonHelpText}"/>
                </StackPanel>

                <!-- Testing -->
                <Grid Visibility="{Binding TestingVisibility}" x:Name="TestingPanel" Height="680"
                      AutomationProperties.Name="Экран тестирования">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Button Content="Выйти" Height="30" Padding="12,0" FontSize="12"
                                Command="{Binding CancelTestCommand}" Background="#FEE2E2" Foreground="#EF4444"
                                FontWeight="SemiBold" BorderThickness="0" VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="Выйти из теста"
                                AutomationProperties.HelpText="Отменить тест и вернуться к выбору"/>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedTestName}" FontSize="26" Foreground="#4F46E5"
                                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        AutomationProperties.Name="{Binding QuestionNumber, StringFormat='Вопрос {0}'}">
                                <TextBlock Text="{Binding QuestionNumber, StringFormat='Вопрос {0}'}"
                                           FontSize="14" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding TotalQuestions, StringFormat=' из {0}'}"
                                           FontSize="14" Foreground="#94A3B8"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    Visibility="{Binding TimerVisibility}"
                                    AutomationProperties.Name="Таймер теста"
                                    AutomationProperties.HelpText="Оставшееся время на тест"
                                    AutomationProperties.LiveSetting="Polite">
                            <TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TimerText}" FontSize="18" FontWeight="Bold"
                                       Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <ProgressBar Grid.Row="1" Height="6" Background="#E2E8F0"
                                 Foreground="#4F46E5" BorderThickness="0" Margin="0,0,0,24"
                                 Value="{Binding ProgressValue}" Minimum="0" Maximum="100"
                                 AutomationProperties.Name="Прогресс тестирования"/>

                    <TextBlock Grid.Row="2" Text="{Binding QuestionTypeHint}" FontSize="14" Foreground="#94A3B8"
                               Margin="0,0,0,6" AutomationProperties.Name="Тип вопроса"/>
                    <TextBlock Grid.Row="2" Text="{Binding QuestionText}" FontSize="20" FontWeight="Bold"
                               Foreground="#1E293B" TextWrapping="Wrap" Margin="0,18,0,24"
                               AutomationProperties.Name="Текст вопроса"/>

                    <ListBox Grid.Row="3" ItemsSource="{Binding CurrentOptions}"
                             SelectedIndex="{Binding SelectedOptionIndex}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             AutomationProperties.Name="Варианты ответа"
                             AutomationProperties.HelpText="Выберите один вариант ответа">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentMultiple}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="itemBorder" Background="White" CornerRadius="10"
                                                    BorderBrush="#E2E8F0" BorderThickness="1.5" Padding="18,14">
                                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="itemBorder" Property="BorderBrush" Value="#A5B4FC"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="itemBorder" Property="BorderBrush" Value="#4F46E5"/>
                                                    <Setter TargetName="itemBorder" Property="Background" Value="#EEF2FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" FontSize="16" Foreground="#1E293B" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ItemsControl Grid.Row="3" ItemsSource="{Binding CurrentOptions}"
                                  AutomationProperties.Name="Варианты ответа"
                                  AutomationProperties.HelpText="Выберите несколько вариантов ответа">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentMultiple}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,0,10" Padding="14,12" HorizontalContentAlignment="Stretch"
                                        Command="{Binding DataContext.ToggleOptionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Index}"
                                        BorderThickness="0" Background="Transparent" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="optBorder" CornerRadius="10" Padding="14,12"
                                                    BorderBrush="#E2E8F0" BorderThickness="1.5" Background="White">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border x:Name="checkBox" Width="22" Height="22" CornerRadius="4"
                                                            BorderBrush="#94A3B8" BorderThickness="1.5" Margin="0,0,12,0"
                                                            VerticalAlignment="Center" Background="White">
                                                        <TextBlock x:Name="checkMark" FontSize="14" FontWeight="Bold"
                                                                   Foreground="#4F46E5" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" Text=""/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Text}" FontSize="16" Foreground="#1E293B"
                                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="optBorder" Property="BorderBrush" Value="#4F46E5"/>
                                                    <Setter TargetName="optBorder" Property="Background" Value="#EEF2FF"/>
                                                    <Setter TargetName="checkBox" Property="BorderBrush" Value="#4F46E5"/>
                                                    <Setter TargetName="checkBox" Property="Background" Value="#4F46E5"/>
                                                    <Setter TargetName="checkMark" Property="Text" Value="&#xE73E;"/>
                                                    <Setter TargetName="checkMark" Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="optBorder" Property="BorderBrush" Value="#A5B4FC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Назад" Height="48" Width="160" Margin="0,0,12,0"
                                Command="{Binding PrevQuestionCommand}" Background="#94A3B8" Foreground="White"
                                FontWeight="SemiBold" FontSize="15" BorderThickness="0"
                                AutomationProperties.Name="Предыдущий вопрос"
                                AutomationProperties.HelpText="Вернуться к предыдущему вопросу"/>
                        <Button Content="{Binding NextButtonText}" Height="48" Width="200"
                                Command="{Binding NextQuestionCommand}" Background="#4F46E5" Foreground="White"
                                FontWeight="Bold" FontSize="15" BorderThickness="0"
                                AutomationProperties.Name="Следующий вопрос"/>
                    </StackPanel>
                </Grid>

                <!-- Review -->
                <Grid Visibility="{Binding ReviewVisibility}" x:Name="ReviewPanel" Height="680"
                      AutomationProperties.Name="Экран проверки ответов">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="Проверка ответов" FontSize="28" FontWeight="Bold"
                                   Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,8"
                                   AutomationProperties.Name="Заголовок проверки ответов"/>
                        <TextBlock Text="Нажмите на вопрос, чтобы вернуться к нему" FontSize="14" Foreground="#64748B"
                                   HorizontalAlignment="Center"
                                   AutomationProperties.Name="Подсказка"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  AutomationProperties.Name="Список вопросов для проверки">
                        <ItemsControl ItemsSource="{Binding ReviewItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,8" Padding="16,12" HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.GoToQuestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Index}"
                                            AutomationProperties.Name="{Binding ReviewAccessibilityName}"
                                            AutomationProperties.HelpText="Нажмите чтобы вернуться к этому вопросу">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="reviewBorder" CornerRadius="10" Padding="16,12"
                                                        BorderThickness="1.5" Cursor="Hand">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                            <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAnswered}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#86EFAC"/>
                                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,12,0"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#CBD5E1"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAnswered}" Value="True">
                                                                            <Setter Property="Background" Value="#86EFAC"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Number}" Foreground="#1E293B" FontWeight="Bold" FontSize="14"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding QuestionText}" FontSize="14" Foreground="#1E293B"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                                    <Setter Property="Text" Value="Не отвечен"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAnswered}" Value="True">
                                                                            <Setter Property="Foreground" Value="#22C55E"/>
                                                                            <Setter Property="Text" Value="Отвечен"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="reviewBorder" Property="BorderBrush" Value="#4F46E5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Выйти из теста" Height="48" Width="180" Margin="0,0,12,0"
                                Command="{Binding CancelTestCommand}" Background="#EF4444" Foreground="White"
                                FontWeight="SemiBold" FontSize="14" BorderThickness="0"
                                AutomationProperties.Name="Выйти из теста"
                                AutomationProperties.HelpText="Отменить тест и вернуться к выбору"/>
                        <Button Content="Отправить результат" Height="48" Width="220"
                                Command="{Binding SubmitCommand}" Background="#4F46E5" Foreground="White"
                                FontWeight="Bold" FontSize="15" BorderThickness="0"
                                AutomationProperties.Name="Отправить результат"
                                AutomationProperties.HelpText="Отправить ответы на сервер"/>
                    </StackPanel>
                </Grid>

                <!-- Result -->
                <Grid Visibility="{Binding ResultVisibility}" x:Name="ResultPanel" Height="680"
                      AutomationProperties.Name="Экран результата тестирования">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="Результат тестирования" FontSize="28" FontWeight="Bold"
                                   Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,16"
                                   AutomationProperties.Name="Заголовок результата"/>
                        <Border Width="100" Height="100" CornerRadius="50" Background="White"
                                BorderThickness="5" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="1">
                                            <Setter Property="BorderBrush" Value="#F97316"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="2">
                                            <Setter Property="BorderBrush" Value="#EAB308"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="3">
                                            <Setter Property="BorderBrush" Value="#22C55E"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="4">
                                            <Setter Property="BorderBrush" Value="#15803D"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScoreLevel}" Value="5">
                                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                                            <Setter Property="BorderThickness" Value="8"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ResultScore}" FontSize="26" FontWeight="Black"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       AutomationProperties.Name="Оценка">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4F46E5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPerfectScore}" Value="True">
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="{Binding ResultCorrect}" FontSize="16" Foreground="#64748B"
                                   HorizontalAlignment="Center"
                                   AutomationProperties.Name="Количество правильных ответов"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  AutomationProperties.Name="Подробности ответов">
                        <ItemsControl ItemsSource="{Binding ResultItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" CornerRadius="10" Padding="16,12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F0FDF4"/>
                                                <Setter Property="BorderBrush" Value="#BBF7D0"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                        <Setter Property="BorderBrush" Value="#FECACA"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,12,0"
                                                    HorizontalAlignment="Center" VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#22C55E"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                <Setter Property="Background" Value="#EF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Foreground="White" FontWeight="Bold" FontSize="14"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="+"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCorrect}" Value="False">
                                                                    <Setter Property="Text" Value="-"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding QuestionText}" FontWeight="SemiBold" Foreground="#0F172A" FontSize="14" TextWrapping="Wrap"/>
                                                <TextBlock Foreground="#64748B" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap">
                                                    <Run Text="Ваш ответ: "/><Run Text="{Binding SelectedAnswer, Mode=OneWay}"/>
                                                    <Run Text="   Правильный: "/><Run Text="{Binding CorrectAnswer, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Button Content="Начать заново" Height="44" Padding="20,0"
                                Command="{Binding RestartCommand}" Background="#E2E8F0" Foreground="#334155"
                                FontWeight="SemiBold" BorderThickness="0"
                                AutomationProperties.Name="Начать заново"
                                AutomationProperties.HelpText="Вернуться к экрану авторизации"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
